[Unit]
Description=Dual Sense 5 Audio Server
Documentation=man:ds5server(1)
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/ds5server
Restart=always
RestartSec=5
# 如果需要在重启前等待窗口关闭，可以调整 RestartSec
# 如果希望只在错误退出时重启而非正常退出，使用 Restart=on-failure

# 环境变量（可选，根据需要添加）
Environment="DISPLAY=:0"
Environment="WAYLAND_DISPLAY=wayland-1"

# 资源限制（可选）
LimitNOFILE=65536

[Install]
WantedBy=graphical-session.target
